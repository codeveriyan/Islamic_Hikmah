# Request a key from https://sunnah.com/developers and keep it on the server.
SUNNAH_API_KEY=replace-with-your-sunnah-com-api-key
# Official docs currently publish v1 routes under https://api.sunnah.com/v1.
SUNNAH_API_BASE_URL=https://api.sunnah.com/v1
# Optional. Defaults to backend/data/sunnah_cache.
SUNNAH_CACHE_DIR=./data/sunnah_cache
